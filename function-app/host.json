{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "default": "Information",
      "Host.Results": "Error",
      "Function": "Information",
      "Host.Aggregator": "Trace"
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "extensions": {
    "blobs": {
      "source": "LogsAndContainerScan",
      "maxDegreeOfParallelism": 4
    },
    "durableTask": {
      "storageProvider": {
        "maxQueuePollingInterval": "00:00:05"
      }
    }
  },
  "functionTimeout": "00:10:00"
}
