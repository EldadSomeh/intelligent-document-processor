{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "14029268908905310605"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "projectName": {
      "type": "string",
      "defaultValue": "preocr",
      "minLength": 3,
      "maxLength": 8,
      "metadata": {
        "description": "Short project prefix (lowercase, no hyphens)."
      }
    },
    "env": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "staging",
        "prod"
      ],
      "metadata": {
        "description": "Environment tag (dev | staging | prod)."
      }
    },
    "imageName": {
      "type": "string",
      "defaultValue": "preocr-func",
      "metadata": {
        "description": "Docker image name (without registry prefix)."
      }
    },
    "imageTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Docker image tag."
      }
    },
    "sourceRepoUrl": {
      "type": "string",
      "defaultValue": "https://github.com/EldadSomeh/intelligent-document-processor.git#main:function-app",
      "metadata": {
        "description": "GitHub repo URL for ACR build (includes Dockerfile)."
      }
    },
    "existingVnetId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: existing VNet resource ID. Leave empty to create a new VNet."
      }
    },
    "vnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.0.0.0/16",
      "metadata": {
        "description": "VNet address space (used only when creating a new VNet)."
      }
    },
    "integrationSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.0.1.0/24",
      "metadata": {
        "description": "Subnet for VNet-integrated apps (Function App)."
      }
    },
    "privateEndpointSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.0.2.0/24",
      "metadata": {
        "description": "Subnet for private endpoints."
      }
    },
    "appGwSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.0.3.0/24",
      "metadata": {
        "description": "Subnet for Application Gateway."
      }
    },
    "funcPlanSku": {
      "type": "string",
      "defaultValue": "B1",
      "metadata": {
        "description": "App Service Plan SKU for the Function App (B1, B2, B3, S1, P1v3, etc.)."
      }
    },
    "funcPlanTier": {
      "type": "string",
      "defaultValue": "Basic",
      "metadata": {
        "description": "App Service Plan tier for the Function App."
      }
    },
    "functionHostKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Function App host key – injected by AG as x-functions-key header."
      }
    }
  },
  "variables": {
    "suffix": "[take(uniqueString(resourceGroup().id), 6)]",
    "storageAccountName": "[format('{0}{1}{2}', parameters('projectName'), parameters('env'), variables('suffix'))]",
    "acrName": "[format('{0}{1}{2}', parameters('projectName'), parameters('env'), variables('suffix'))]",
    "appInsightsName": "[format('{0}-{1}-ai-{2}', parameters('projectName'), parameters('env'), variables('suffix'))]",
    "funcPlanName": "[format('{0}-{1}-func-plan', parameters('projectName'), parameters('env'))]",
    "funcAppName": "[format('{0}-{1}-func-{2}', parameters('projectName'), parameters('env'), variables('suffix'))]",
    "buildScriptName": "[format('{0}-{1}-build-image', parameters('projectName'), parameters('env'))]",
    "buildIdentityName": "[format('{0}-{1}-build-id', parameters('projectName'), parameters('env'))]",
    "vnetName": "[format('{0}-{1}-vnet-{2}', parameters('projectName'), parameters('env'), variables('suffix'))]",
    "integrationSubnetName": "snet-integration",
    "peSubnetName": "snet-private-endpoints",
    "appGwSubnetName": "snet-appgw",
    "appGwName": "[format('{0}-{1}-appgw', parameters('projectName'), parameters('env'))]",
    "appGwPipName": "[format('{0}-{1}-appgw-pip', parameters('projectName'), parameters('env'))]",
    "appGwPipDnsLabel": "[format('{0}-{1}-{2}', parameters('projectName'), parameters('env'), variables('suffix'))]",
    "storageBlobDataOwner": "b7e6dc6d-f1e8-4753-8033-0f276bb0955b",
    "storageQueueDataContributor": "974c5e8b-45b9-4653-ba55-5f855dd0fb88",
    "storageTableDataContributor": "0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3",
    "effectiveVnetId": "[if(empty(parameters('existingVnetId')), resourceId('Microsoft.Network/virtualNetworks', variables('vnetName')), parameters('existingVnetId'))]",
    "integrationSubnetId": "[format('{0}/subnets/{1}', variables('effectiveVnetId'), variables('integrationSubnetName'))]",
    "privateEndpointSubnetId": "[format('{0}/subnets/{1}', variables('effectiveVnetId'), variables('peSubnetName'))]",
    "appGwSubnetId": "[format('{0}/subnets/{1}', variables('effectiveVnetId'), variables('appGwSubnetName'))]",
    "privateDnsZones": [
      "[format('privatelink.blob.{0}', environment().suffixes.storage)]",
      "[format('privatelink.queue.{0}', environment().suffixes.storage)]",
      "[format('privatelink.table.{0}', environment().suffixes.storage)]",
      "[format('privatelink.file.{0}', environment().suffixes.storage)]"
    ],
    "peSubResources": [
      {
        "name": "blob",
        "groupId": "blob",
        "dnsIdx": 0
      },
      {
        "name": "queue",
        "groupId": "queue",
        "dnsIdx": 1
      },
      {
        "name": "table",
        "groupId": "table",
        "dnsIdx": 2
      },
      {
        "name": "file",
        "groupId": "file",
        "dnsIdx": 3
      }
    ]
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "allowSharedKeyAccess": true,
        "publicNetworkAccess": "Disabled",
        "networkAcls": {
          "defaultAction": "Deny",
          "bypass": "AzureServices"
        }
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', variables('storageAccountName'), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', variables('storageAccountName'), 'default', 'raw')]",
