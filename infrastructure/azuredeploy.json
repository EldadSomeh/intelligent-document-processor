    "buildIdentityName": "[format('{0}-{1}-build-id', parameters('projectName'), parameters('env'))]",
    "vnetName": "[format('{0}-{1}-vnet-{2}', parameters('projectName'), parameters('env'), variables('suffix'))]",
    "integrationSubnetName": "snet-integration",
    "peSubnetName": "snet-private-endpoints",
    "storageBlobDataOwner": "b7e6dc6d-f1e8-4753-8033-0f276bb0955b",
    "storageQueueDataContributor": "974c5e8b-45b9-4653-ba55-5f855dd0fb88",
