      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', variables('storageAccountName'), 'default', 'artifacts')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', variables('storageAccountName'), 'default', 'outputs')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccountName'), 'default')]"
      ]
    },
    {
      "condition": "[empty(parameters('existingVnetId'))]",
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('vnetAddressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('integrationSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('integrationSubnetPrefix')]",
              "delegations": [
                {
                  "name": "delegation-serverfarms",
                  "properties": {
                    "serviceName": "Microsoft.Web/serverFarms"
                  }
                }
              ]
            }
          },
          {
            "name": "[variables('peSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('privateEndpointSubnetPrefix')]",
              "privateEndpointNetworkPolicies": "Disabled"
            }
          },
          {
            "name": "[variables('appGwSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('appGwSubnetPrefix')]"
            }
          }
        ]
      }
    },
    {
      "copy": {
        "name": "dnsZones",
        "count": "[length(variables('privateDnsZones'))]"
      },
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "[variables('privateDnsZones')[copyIndex()]]",
      "location": "global"
    },
    {
      "copy": {
        "name": "dnsVnetLinks",
        "count": "[length(variables('privateDnsZones'))]"
      },
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', variables('privateDnsZones')[copyIndex()], format('{0}-link', variables('vnetName')))]",
      "location": "global",
      "properties": {
        "virtualNetwork": {
          "id": "[variables('effectiveVnetId')]"
        },
        "registrationEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', variables('privateDnsZones')[copyIndex()])]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "copy": {
        "name": "privateEndpoints",
        "count": "[length(variables('peSubResources'))]"
      },
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}-pe-{1}', variables('storageAccountName'), variables('peSubResources')[copyIndex()].name)]",
      "location": "[parameters('location')]",
      "properties": {
        "subnet": {
          "id": "[variables('privateEndpointSubnetId')]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "[format('{0}-{1}', variables('storageAccountName'), variables('peSubResources')[copyIndex()].name)]",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
              "groupIds": [
                "[variables('peSubResources')[copyIndex()].groupId]"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "copy": {
        "name": "peDnsGroups",
        "count": "[length(variables('peSubResources'))]"
      },
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', format('{0}-pe-{1}', variables('storageAccountName'), variables('peSubResources')[copyIndex()].name), 'default')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "[format('config-{0}', variables('peSubResources')[copyIndex()].name)]",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', variables('privateDnsZones')[variables('peSubResources')[copyIndex()].dnsIdx])]"
