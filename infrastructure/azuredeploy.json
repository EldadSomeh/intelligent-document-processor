      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}-pe-{1}', variables('storageAccountName'), variables('peSubResources')[copyIndex()].name)]",
      "location": "[parameters('location')]",
      "properties": {
        "subnet": {
