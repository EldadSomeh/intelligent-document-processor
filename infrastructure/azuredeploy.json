      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', format('{0}-pe-{1}', variables('storageAccountName'), variables('peSubResources')[copyIndex()].name), 'default')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "[format('config-{0}', variables('peSubResources')[copyIndex()].name)]",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', variables('privateDnsZones')[variables('peSubResources')[copyIndex()].dnsIdx])]"
