    {
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "[variables('buildScriptName')]",
      "location": "[parameters('location')]",
      "kind": "AzureCLI",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('buildIdentityName')))]": {}
        }
      },
      "properties": {
        "azCliVersion": "2.63.0",
        "timeout": "PT30M",
        "retentionInterval": "P1D",
        "environmentVariables": [
          {
            "name": "ACR_NAME",
            "value": "[variables('acrName')]"
          },
          {
            "name": "ACR_LOGIN",
            "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer]"
          },
          {
            "name": "IMAGE_NAME",
            "value": "[parameters('imageName')]"
          },
          {
            "name": "IMAGE_TAG",
            "value": "[parameters('imageTag')]"
          },
          {
            "name": "SOURCE_REPO",
            "value": "[parameters('sourceRepoUrl')]"
          },
          {
            "name": "RG_NAME",
            "value": "[resourceGroup().name]"
          },
          {
            "name": "FUNC_APP_NAME",
            "value": "[variables('funcAppName')]"
          }
        ],
        "scriptContent": "      echo \"Building Docker image in ACR...\"\r\n      az acr build --registry $ACR_NAME --image $IMAGE_NAME:$IMAGE_TAG $SOURCE_REPO --no-logs 2>&1 || {\r\n        echo \"ACR build failed, retrying...\"\r\n        sleep 10\r\n        az acr build --registry $ACR_NAME --image $IMAGE_NAME:$IMAGE_TAG $SOURCE_REPO 2>&1\r\n      }\r\n      echo \"Configuring Function App to use the new image...\"\r\n      az functionapp config container set \\\r\n        --resource-group $RG_NAME \\\r\n        --name $FUNC_APP_NAME \\\r\n        --image \"$ACR_LOGIN/$IMAGE_NAME:$IMAGE_TAG\" \\\r\n        --registry-server \"https://$ACR_LOGIN\" 2>&1\r\n      echo \"Restarting Function App to pull new image...\"\r\n      az functionapp restart --resource-group $RG_NAME --name $FUNC_APP_NAME 2>&1\r\n      echo \"Waiting for Function App to start...\"\r\n      sleep 60\r\n      # Retrieve the default function key and persist as app setting\r\n      echo \"Retrieving default function key...\"\r\n      for i in 1 2 3 4 5; do\r\n        FUNC_KEY=$(az functionapp keys list --resource-group $RG_NAME --name $FUNC_APP_NAME --query \"functionKeys.default\" -o tsv 2>/dev/null)\r\n        if [ -n \"$FUNC_KEY\" ] && [ \"$FUNC_KEY\" != \"None\" ]; then\r\n          echo \"Function key retrieved on attempt $i\"\r\n          break\r\n        fi\r\n        echo \"Attempt $i: Function key not ready, waiting 30s...\"\r\n        sleep 30\r\n      done\r\n      if [ -n \"$FUNC_KEY\" ] && [ \"$FUNC_KEY\" != \"None\" ]; then\r\n        az functionapp config appsettings set \\\r\n          --resource-group $RG_NAME --name $FUNC_APP_NAME \\\r\n          --settings \"PREOCR_FUNCTION_KEY=$FUNC_KEY\" --output none 2>&1\r\n        echo \"Function key persisted as PREOCR_FUNCTION_KEY\"\r\n      else\r\n        echo \"WARNING: Could not retrieve function key. Set PREOCR_FUNCTION_KEY manually.\"\r\n      fi\r\n      echo \"Done!\"\r\n    "
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[extensionResourceId(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('buildIdentityName')), '8311e382-0749-4cb8-b61a-304f252e45ec'))]",
        "[resourceId('Microsoft.Authorization/roleAssignments', guid(resourceGroup().id, resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('buildIdentityName')), 'b24988ac-6180-42a0-ab88-20f7382dd24c'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('buildIdentityName'))]",
        "[resourceId('Microsoft.Web/sites', variables('funcAppName'))]"
      ]
    }
  ],
  "outputs": {
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
